# --------------------------------------------
# 开发模式
# --------------------------------------------
ENV_IS_DEV=true

# 开发环境短信验证码（仅开发模式有效）
ENV_DEV_PASSPORT_SMS_CODE=<your_dev_sms_code>

# --------------------------------------------
# 数据库 (MySQL)
# --------------------------------------------
ENV_DB_USER=<your_db_user>
ENV_DB_PASS=<your_db_password>
ENV_DB_ADDR=<your_db_host>:<your_db_port>
ENV_DB_NAME=<your_db_name>

# --------------------------------------------
# 对象存储 (MinIO)
# --------------------------------------------
ENV_OSS_USER=<your_oss_user>
ENV_OSS_PASS=<your_oss_password>
ENV_OSS_AK=<your_oss_access_key>
ENV_OSS_SK=<your_oss_secret_key>
ENV_OSS_ENDPOINT_HOST=<your_oss_host>
ENV_OSS_ENDPOINT_PORT=<your_oss_port>
ENV_OSS_ENDPOINT_LOCATION=local
ENV_OSS_ENDPOINT=<your_oss_host>:<your_oss_port>

# AWS S3 兼容配置（用于 imgproxy）
AWS_ACCESS_KEY_ID=<your_aws_access_key>
AWS_SECRET_ACCESS_KEY=<your_aws_secret_key>

# --------------------------------------------
# Nginx / s1-gate 配置
# --------------------------------------------
NGINX_UPSTREAM_MINIO_SERVER=<your_minio_host>:<your_minio_port>
NGINX_UPSTREAM_IMGPROXY_SERVER=<your_imgproxy_host>:<your_imgproxy_port>
NGINX_ACCESS_CORS_ALLOWED_ORIGIN=<your_cors_allowed_origin>

# --------------------------------------------
# 图片处理 (imgproxy)
# --------------------------------------------
IMGPROXY_KEY=<your_imgproxy_key>
IMGPROXY_SALT=<your_imgproxy_salt>

# --------------------------------------------
# 用户认证 (passport)
# --------------------------------------------
ENV_PASSPORT_ENCRYPT_KEY=<your_encrypt_key>
ENV_PASSPORT_ENCRYPT_SECRET=<your_encrypt_secret>

# JWT 验证配置
ENV_JWT_VALID_ISSUER=whimer
ENV_JWT_VALID_SUBJECT=sts

# --------------------------------------------
# ID 混淆盐值
# --------------------------------------------
ENV_NOTE_SALT=<your_note_salt>
ENV_OBFUSCATE_NOTE_SALT=<your_note_obfuscate_salt>
ENV_OBFUSCATE_TAG_SALT=<your_tag_obfuscate_salt>
ENV_OBFUSCATE_COUNTER_SALT=<your_counter_obfuscate_salt>

# --------------------------------------------
# 搜索引擎 (Elasticsearch)
# --------------------------------------------
ENV_ES_ADDR=http://<your_es_host>:<your_es_port>
ENV_ES_USER=<your_es_user>
ENV_ES_PASSWORD=<your_es_password>

# --------------------------------------------
# 消息队列 (Kafka)
# --------------------------------------------
ENV_KFK_USERNAME=<your_kafka_user>
ENV_KFK_PASSWORD=<your_kafka_password>
ENV_KFK_BROKERS=<your_kafka_host>:<your_kafka_port>

# --------------------------------------------
# 缓存 (Redis)
# --------------------------------------------
ENV_REDIS_HOST=<your_redis_host>:<your_redis_port>

# --------------------------------------------
# 服务发现 (etcd)
# --------------------------------------------
ENV_ETCD_HOSTS='[<your_etcd_host>:<your_etcd_port>]'

# --------------------------------------------
# 链路追踪 (Jaeger)
# --------------------------------------------
ENV_JAEGER_ENDPOINT=http://<your_jaeger_host>:14268/api/traces
